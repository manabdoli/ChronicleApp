{
  "entities": {
    "Event": {
      "title": "Event",
      "description": "A recorded event or scheduled task.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the event" },
        "description": { "type": "string", "description": "Optional detailed description" },
        "date": { "type": "string", "format": "date-time", "description": "Scheduled date and time" },
        "category": { "type": "string", "enum": ["photo", "email", "audio", "note"], "description": "Source type of the event" },
        "mediaUrl": { "type": "string", "description": "URL to photo or audio asset" },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "Custom tags for organization" },
        "recurring": { "type": "string", "enum": ["none", "daily", "weekly", "monthly"], "description": "Recurrence pattern" },
        "userId": { "type": "string", "description": "Owner of the event" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "date", "category", "userId"]
    }
  },
  "firestore": {
    "events/{eventId}": {
      "schema": "Event",
      "description": "User events and scheduled items"
    }
  }
}
