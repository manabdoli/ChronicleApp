rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidEvent(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.category in ['photo', 'email', 'audio', 'note'] &&
             data.date is timestamp &&
             data.userId == request.auth.uid &&
             (data.description == null || (data.description is string && data.description.size() <= 2000)) &&
             (data.tags == null || (data.tags is list && data.tags.size() <= 10)) &&
             (data.recurring in ['none', 'daily', 'weekly', 'monthly']) &&
             data.createdAt == (resource == null ? request.time : existing().createdAt) &&
             data.updatedAt == request.time;
    }

    match /events/{eventId} {
      allow get: if isSignedIn() && isOwner(existing().userId);
      allow list: if isSignedIn() && request.query.limit <= 100 && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && 
                      isValidId(eventId) && 
                      isValidEvent(incoming());
      
      allow update: if isSignedIn() && 
                      isOwner(existing().userId) && 
                      isValidEvent(incoming()) &&
                      incoming().userId == existing().userId &&
                      incoming().createdAt == existing().createdAt;
      
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }
  }
}
